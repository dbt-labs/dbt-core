# Cross-phase key-set documentation.
#
# This file is the living source-of-truth for "which Jinja key appears in
# which phase, and with what concrete value." Fixtures populated so far:
#   * load              (PR 1)
#   * resolve_globals   (PR 2)
# Future PRs will flip the remaining `<skip>` placeholders to real
# expectations as resolve_base / resolve_model / compile_* / run_node land.

key target.name
----
load              dev
resolve_globals   dev
resolve_base      <skip>
resolve_model     <skip>
compile_base      <skip>
compile_node      <skip>
run_node          <skip>

key flags.FULL_REFRESH
----
load              false
resolve_globals   false
resolve_base      <skip>
resolve_model     <skip>
compile_base      <skip>
compile_node      <skip>
run_node          <skip>

key run_started_at
----
load              <object>
resolve_globals   <object>
resolve_base      <skip>
resolve_model     <skip>
compile_base      <skip>
compile_node      <skip>
run_node          <skip>

# Project-name only appears starting at the resolve (parse) phase — at load
# this key is absent.
key project_name
----
load              <absent>
resolve_globals   my_project
resolve_base      <skip>
resolve_model     <skip>
compile_base      <skip>
compile_node      <skip>
run_node          <skip>

# `env` is a parse-and-onward alias of `target`. Absent at load.
key env.name
----
load              <absent>
resolve_globals   dev
resolve_base      <skip>
resolve_model     <skip>
compile_base      <skip>
compile_node      <skip>
run_node          <skip>

# `var`, `database`, `schema`, `invocation_id`, `invocation_args_dict`, `write`
# are introduced at parse and carry through compile + run on the same env.
key var
----
load              <absent>
resolve_globals   <object>
resolve_base      <skip>
resolve_model     <skip>
compile_base      <skip>
compile_node      <skip>
run_node          <skip>

key database
----
load              <absent>
resolve_globals   analytics
resolve_base      <skip>
resolve_model     <skip>
compile_base      <skip>
compile_node      <skip>
run_node          <skip>

key schema
----
load              <absent>
resolve_globals   public
resolve_base      <skip>
resolve_model     <skip>
compile_base      <skip>
compile_node      <skip>
run_node          <skip>

key invocation_id
----
load              <absent>
resolve_globals   11111111-2222-3333-4444-555555555555
resolve_base      <skip>
resolve_model     <skip>
compile_base      <skip>
compile_node      <skip>
run_node          <skip>

key write
----
load              <absent>
resolve_globals   null
resolve_base      <skip>
resolve_model     <skip>
compile_base      <skip>
compile_node      <skip>
run_node          <skip>

# `execute` is unset at load (no `execute` key on the load env), absent at
# resolve_globals (only added by per-render contexts), false at resolve_base
# / resolve_model, true at compile + run. Future PRs will fill this in.
key execute
----
load              <absent>
resolve_globals   <absent>
resolve_base      <skip>
resolve_model     <skip>
compile_base      <skip>
compile_node      <skip>
run_node          <skip>

# Callable Jinja values: ref/source/config/this only appear once we have a
# resolve-model or compile-node ctx. Until then, future-PR rows are skipped.
# At resolve_globals these are absent — they live on per-render contexts, not
# env globals.
key ref
----
load              <absent>
resolve_globals   <absent>
resolve_base      <skip>
resolve_model     <skip>
compile_base      <skip>
compile_node      <skip>
run_node          <skip>

key source
----
load              <absent>
resolve_globals   <absent>
resolve_base      <skip>
resolve_model     <skip>
compile_base      <skip>
compile_node      <skip>
run_node          <skip>

key config
----
load              <absent>
resolve_globals   <absent>
resolve_base      <skip>
resolve_model     <skip>
compile_base      <skip>
compile_node      <skip>
run_node          <skip>

key this
----
load              <absent>
resolve_globals   <absent>
resolve_base      <skip>
resolve_model     <skip>
compile_base      <skip>
compile_node      <skip>
run_node          <skip>
